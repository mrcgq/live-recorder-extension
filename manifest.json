{
  "manifest_version": 3,
  "name": "🎬 极简直播内录器 Pro",
  "version": "3.2.1",
  "description": "基于跨进程管道化隔离架构的轻量级直录器，0%网页卡顿，100%防崩自愈。",
  "permissions": [
    "activeTab",
    "storage",
    "downloads",
    "tabCapture"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["recorder.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
